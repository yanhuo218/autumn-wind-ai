{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autumn-wind.ai/contracts/frontend/http-response.schema.json",
  "$defs": {
    "conversation.ConversationCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "conversation.GenerationCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clientRequestId",
        "modelId",
        "content"
      ],
      "properties": {
        "clientRequestId": {
          "type": "string",
          "format": "uuid"
        },
        "modelId": {
          "type": "string",
          "format": "uuid"
        },
        "content": {
          "$ref": "#/$defs/conversation.MessageContent"
        }
      }
    },
    "conversation.RegenerateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clientRequestId"
      ],
      "properties": {
        "clientRequestId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "conversation.MessageContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "blocks"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/conversation.ContentBlock"
          }
        }
      }
    },
    "conversation.ContentBlock": {
      "oneOf": [
        {
          "$ref": "#/$defs/conversation.TextContentBlock"
        },
        {
          "$ref": "#/$defs/conversation.ImageReferenceContentBlock"
        },
        {
          "$ref": "#/$defs/conversation.FileReferenceContentBlock"
        }
      ]
    },
    "conversation.TextContentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "conversation.ImageReferenceContentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "resourceId"
      ],
      "properties": {
        "type": {
          "const": "image_ref"
        },
        "resourceId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "conversation.FileReferenceContentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "resourceId"
      ],
      "properties": {
        "type": {
          "const": "file_ref"
        },
        "resourceId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "conversation.GenerationStatus": {
      "type": "string",
      "enum": [
        "PENDING",
        "STREAMING",
        "SUCCEEDED",
        "FAILED",
        "STOPPED",
        "INTERRUPTED"
      ]
    },
    "conversation.ConversationView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "conversationId",
        "title",
        "createdAt",
        "archived"
      ],
      "properties": {
        "conversationId": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "archived": {
          "type": "boolean"
        }
      }
    },
    "conversation.ConversationListView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conversation.ConversationView"
          }
        }
      }
    },
    "conversation.ConversationDetailView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "conversationId",
        "title",
        "createdAt",
        "archived",
        "generations",
        "messages"
      ],
      "properties": {
        "conversationId": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "archived": {
          "type": "boolean"
        },
        "generations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conversation.GenerationView"
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conversation.MessageView"
          }
        }
      }
    },
    "conversation.MessageRole": {
      "type": "string",
      "enum": [
        "USER",
        "ASSISTANT"
      ]
    },
    "conversation.MessageCompleteness": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "PARTIAL"
      ]
    },
    "conversation.MessageView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "messageId",
        "role",
        "content",
        "completeness",
        "generationId",
        "createdAt"
      ],
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "role": {
          "$ref": "#/$defs/conversation.MessageRole"
        },
        "content": {
          "$ref": "#/$defs/conversation.MessageContent"
        },
        "completeness": {
          "$ref": "#/$defs/conversation.MessageCompleteness"
        },
        "generationId": {
          "oneOf": [
            {
              "type": "string",
              "format": "uuid"
            },
            {
              "type": "null"
            }
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "role": {
                  "const": "USER"
                },
                "generationId": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "role": {
                  "const": "ASSISTANT"
                },
                "generationId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          ]
        }
      ]
    },
    "conversation.GenerationAcceptedView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "userMessageId",
        "generationId",
        "statusUrl",
        "eventsUrl"
      ],
      "properties": {
        "userMessageId": {
          "type": "string",
          "format": "uuid"
        },
        "generationId": {
          "type": "string",
          "format": "uuid"
        },
        "statusUrl": {
          "type": "string",
          "format": "uri-reference"
        },
        "eventsUrl": {
          "type": "string",
          "format": "uri-reference"
        }
      }
    },
    "conversation.GenerationView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "generationId",
        "conversationId",
        "status",
        "content",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "generationId": {
          "type": "string",
          "format": "uuid"
        },
        "conversationId": {
          "type": "string",
          "format": "uuid"
        },
        "status": {
          "$ref": "#/$defs/conversation.GenerationStatus"
        },
        "content": {
          "$ref": "#/$defs/conversation.MessageContent"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "error": {
          "oneOf": [
            {
              "$ref": "#/$defs/conversation.ErrorResponse"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "conversation.ErrorResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "code",
        "message",
        "correlationId"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^AW-CONVERSATION-(NOT_FOUND|CONFLICT|VALIDATION|DEPENDENCY|RATE_LIMIT|INTERNAL)-[0-9]{4}$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "modelRegistry.EndpointCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "displayName",
        "baseUrl",
        "protocol",
        "requestTimeoutSeconds",
        "enabled",
        "apiKey"
      ],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "baseUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "OPENAI_COMPATIBLE"
          ]
        },
        "requestTimeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "enabled": {
          "type": "boolean"
        },
        "apiKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "writeOnly": true
        }
      }
    },
    "modelRegistry.EndpointCredentialReplaceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apiKey",
        "expectedVersion"
      ],
      "properties": {
        "apiKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "writeOnly": true
        },
        "expectedVersion": {
          "type": "integer",
          "format": "int64",
          "minimum": 0
        }
      }
    },
    "modelRegistry.EndpointView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerUserId",
        "displayName",
        "baseUrl",
        "protocol",
        "requestTimeoutSeconds",
        "enabled",
        "credentialConfigured",
        "version",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "ownerUserId": {
          "type": "string",
          "format": "uuid"
        },
        "displayName": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "OPENAI_COMPATIBLE"
          ]
        },
        "requestTimeoutSeconds": {
          "type": "integer"
        },
        "enabled": {
          "type": "boolean"
        },
        "credentialConfigured": {
          "type": "boolean"
        },
        "version": {
          "type": "integer",
          "format": "int64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "modelRegistry.EndpointConnectionTestRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedVersion"
      ],
      "properties": {
        "expectedVersion": {
          "type": "integer",
          "format": "int64",
          "minimum": 0
        }
      }
    },
    "modelRegistry.EndpointConnectionTestView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jobId",
        "endpointId",
        "status",
        "endpointVersion",
        "createdAt"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "format": "uuid"
        },
        "endpointId": {
          "type": "string",
          "format": "uuid"
        },
        "status": {
          "type": "string",
          "enum": [
            "QUEUED",
            "RUNNING",
            "SUCCEEDED",
            "FAILED",
            "CANCELLED"
          ]
        },
        "endpointVersion": {
          "type": "integer",
          "format": "int64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "modelRegistry.ModelCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interfaceType",
        "inputModalities",
        "outputModality",
        "streaming",
        "systemPrompt",
        "reasoning",
        "contextLength",
        "maxOutputLength"
      ],
      "properties": {
        "interfaceType": {
          "type": "string",
          "enum": [
            "CHAT_COMPLETIONS",
            "IMAGE_GENERATION"
          ]
        },
        "inputModalities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "TEXT",
              "IMAGE",
              "FILE",
              "VIDEO"
            ]
          }
        },
        "outputModality": {
          "type": "string",
          "enum": [
            "TEXT",
            "IMAGE"
          ]
        },
        "streaming": {
          "type": "boolean"
        },
        "systemPrompt": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        },
        "contextLength": {
          "type": "integer",
          "minimum": 1
        },
        "maxOutputLength": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "modelRegistry.ModelCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpointId",
        "providerModelId",
        "displayName",
        "capabilities",
        "enabled",
        "defaultModel"
      ],
      "properties": {
        "endpointId": {
          "type": "string",
          "format": "uuid"
        },
        "providerModelId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "capabilities": {
          "$ref": "#/$defs/modelRegistry.ModelCapabilities"
        },
        "enabled": {
          "type": "boolean"
        },
        "defaultModel": {
          "type": "boolean"
        }
      }
    },
    "modelRegistry.ModelUpdateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerModelId",
        "displayName",
        "capabilities",
        "enabled",
        "defaultModel",
        "expectedVersion"
      ],
      "properties": {
        "providerModelId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "capabilities": {
          "$ref": "#/$defs/modelRegistry.ModelCapabilities"
        },
        "enabled": {
          "type": "boolean"
        },
        "defaultModel": {
          "type": "boolean"
        },
        "expectedVersion": {
          "type": "integer",
          "format": "int64",
          "minimum": 0
        }
      }
    },
    "modelRegistry.ModelView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerUserId",
        "endpointId",
        "providerModelId",
        "displayName",
        "capabilities",
        "enabled",
        "defaultModel",
        "capabilitySchemaVersion",
        "version",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "ownerUserId": {
          "type": "string",
          "format": "uuid"
        },
        "endpointId": {
          "type": "string",
          "format": "uuid"
        },
        "providerModelId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "capabilities": {
          "$ref": "#/$defs/modelRegistry.ModelCapabilities"
        },
        "enabled": {
          "type": "boolean"
        },
        "defaultModel": {
          "type": "boolean"
        },
        "capabilitySchemaVersion": {
          "type": "integer"
        },
        "version": {
          "type": "integer",
          "format": "int64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "modelRegistry.ErrorResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "code",
        "message",
        "correlationId"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^AW-MODEL_REGISTRY-[A-Z][A-Z0-9_]{1,31}-[0-9]{4}$"
        },
        "message": {
          "type": "string"
        },
        "correlationId": {
          "type": "string",
          "minLength": 16,
          "maxLength": 64
        },
        "fieldErrors": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "ConversationListView": {
      "$ref": "#/$defs/conversation.ConversationListView"
    },
    "ConversationDetailView": {
      "$ref": "#/$defs/conversation.ConversationDetailView"
    },
    "ConversationView": {
      "$ref": "#/$defs/conversation.ConversationView"
    },
    "GenerationAcceptedView": {
      "$ref": "#/$defs/conversation.GenerationAcceptedView"
    },
    "GenerationView": {
      "$ref": "#/$defs/conversation.GenerationView"
    },
    "ConversationErrorResponse": {
      "$ref": "#/$defs/conversation.ErrorResponse"
    },
    "ModelViewList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelRegistry.ModelView"
      }
    },
    "ModelRegistryErrorResponse": {
      "$ref": "#/$defs/modelRegistry.ErrorResponse"
    }
  }
}
