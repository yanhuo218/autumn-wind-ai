{
  "openapi": "3.1.0",
  "info": {
    "title": "Autumn Wind AI Conversation API",
    "version": "1.0.0",
    "description": "会话、生成快照与 SSE 事件流的公共契约。"
  },
  "servers": [
    {
      "url": "/",
      "description": "同源 API"
    }
  ],
  "security": [
    {
      "ServiceJwt": []
    }
  ],
  "paths": {
    "/api/v1/conversations": {
      "post": {
        "operationId": "createConversation",
        "summary": "创建会话",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversationCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "会话已创建。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationView"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "get": {
        "operationId": "listConversations",
        "summary": "列出会话",
        "responses": {
          "200": {
            "description": "会话列表。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationListView"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/conversations/{conversationId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ConversationId"
        }
      ],
      "get": {
        "operationId": "getConversation",
        "summary": "读取会话详情",
        "responses": {
          "200": {
            "description": "会话详情。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetailView"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "operationId": "archiveConversation",
        "summary": "归档会话",
        "responses": {
          "204": {
            "description": "会话已归档。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/conversations/{conversationId}/generations": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ConversationId"
        }
      ],
      "post": {
        "operationId": "createGeneration",
        "summary": "创建生成",
        "description": "同一会话内重复提交相同 clientRequestId 时返回原生成，不重复启动推理。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationCreateRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "生成已接受。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationAcceptedView"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/generations/{generationId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/GenerationId"
        }
      ],
      "get": {
        "operationId": "getGeneration",
        "summary": "读取生成快照",
        "responses": {
          "200": {
            "description": "生成快照。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationView"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/generations/{generationId}/events": {
      "parameters": [
        {
          "$ref": "#/components/parameters/GenerationId"
        }
      ],
      "get": {
        "operationId": "streamGenerationEvents",
        "summary": "订阅生成事件",
        "description": "返回标准 SSE 帧。网关和反向代理必须禁用响应缓冲，并及时向客户端刷新每个事件。客户端可使用 Last-Event-ID 断点续传。",
        "parameters": [
          {
            "name": "Last-Event-ID",
            "in": "header",
            "required": false,
            "description": "客户端最后成功处理的事件 ID；服务端仅重放其后的事件。",
            "schema": {
              "type": "string",
              "minLength": 16,
              "maxLength": 64
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE 事件流；代理必须禁用缓冲并保持流式刷新。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              },
              "Cache-Control": {
                "description": "禁止缓存事件流。",
                "schema": {
                  "type": "string",
                  "const": "no-cache"
                }
              },
              "X-Accel-Buffering": {
                "description": "明确禁用兼容代理的响应缓冲。",
                "schema": {
                  "type": "string",
                  "const": "no"
                }
              }
            },
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "data 字段包含符合 conversation-stream-event.v1.schema.json 的 JSON 信封。"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/generations/{generationId}/stop": {
      "parameters": [
        {
          "$ref": "#/components/parameters/GenerationId"
        }
      ],
      "post": {
        "operationId": "stopGeneration",
        "summary": "停止生成",
        "responses": {
          "200": {
            "description": "停止后的生成快照。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationView"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/generations/{generationId}/regenerate": {
      "parameters": [
        {
          "$ref": "#/components/parameters/GenerationId"
        }
      ],
      "post": {
        "operationId": "regenerateGeneration",
        "summary": "重新生成",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegenerateRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "新生成已接受。",
            "headers": {
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationAcceptedView"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ServiceJwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "服务 JWT。会话管理需要 conversation.manage scope，生成操作需要 conversation.generate scope；代表用户执行时必须携带 actor_user_id claim。"
      }
    },
    "headers": {
      "CorrelationId": {
        "description": "端到端关联 ID。",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "parameters": {
      "ConversationId": {
        "name": "conversationId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "GenerationId": {
        "name": "generationId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求无效。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Unauthorized": {
        "description": "未认证。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Forbidden": {
        "description": "无权执行。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotFound": {
        "description": "资源不存在。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Conflict": {
        "description": "资源状态冲突。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotAcceptable": {
        "description": "不支持请求的响应格式。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "UnsupportedMediaType": {
        "description": "不支持请求体媒体类型。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "InternalServerError": {
        "description": "服务内部错误。",
        "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    },
    "schemas": {
      "ConversationCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      },
      "GenerationCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clientRequestId", "modelId", "content"],
        "properties": {
          "clientRequestId": {
            "type": "string",
            "format": "uuid"
          },
          "modelId": {
            "type": "string",
            "format": "uuid"
          },
          "content": {
            "$ref": "#/components/schemas/MessageContent"
          }
        }
      },
      "RegenerateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clientRequestId"],
        "properties": {
          "clientRequestId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "MessageContent": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "blocks"],
        "properties": {
          "schemaVersion": {
            "const": 1
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/ContentBlock"
            }
          }
        }
      },
      "ContentBlock": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/TextContentBlock"
          },
          {
            "$ref": "#/components/schemas/ImageReferenceContentBlock"
          },
          {
            "$ref": "#/components/schemas/FileReferenceContentBlock"
          }
        ]
      },
      "TextContentBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "text"],
        "properties": {
          "type": { "const": "text" },
          "text": { "type": "string", "minLength": 1 }
        }
      },
      "ImageReferenceContentBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "resourceId"],
        "properties": {
          "type": { "const": "image_ref" },
          "resourceId": { "type": "string", "format": "uuid" }
        }
      },
      "FileReferenceContentBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "resourceId"],
        "properties": {
          "type": { "const": "file_ref" },
          "resourceId": { "type": "string", "format": "uuid" }
        }
      },
      "GenerationStatus": {
        "type": "string",
        "enum": ["PENDING", "STREAMING", "SUCCEEDED", "FAILED", "STOPPED", "INTERRUPTED"]
      },
      "ConversationView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["conversationId", "title", "createdAt", "archived"],
        "properties": {
          "conversationId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "archived": { "type": "boolean" }
        }
      },
      "ConversationListView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ConversationView" }
          }
        }
      },
      "ConversationDetailView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["conversationId", "title", "createdAt", "archived", "generations", "messages"],
        "properties": {
          "conversationId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "archived": { "type": "boolean" },
          "generations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GenerationView" }
          },
          "messages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MessageView" }
          }
        }
      },
      "MessageRole": {
        "type": "string",
        "enum": ["USER", "ASSISTANT"]
      },
      "MessageCompleteness": {
        "type": "string",
        "enum": ["COMPLETE", "PARTIAL"]
      },
      "MessageView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["messageId", "role", "content", "completeness", "generationId", "createdAt"],
        "properties": {
          "messageId": { "type": "string", "format": "uuid" },
          "role": { "$ref": "#/components/schemas/MessageRole" },
          "content": { "$ref": "#/components/schemas/MessageContent" },
          "completeness": { "$ref": "#/components/schemas/MessageCompleteness" },
          "generationId": {
            "oneOf": [
              { "type": "string", "format": "uuid" },
              { "type": "null" }
            ]
          },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "allOf": [
          {
            "oneOf": [
              {
                "properties": {
                  "role": { "const": "USER" },
                  "generationId": { "type": "null" }
                }
              },
              {
                "properties": {
                  "role": { "const": "ASSISTANT" },
                  "generationId": { "type": "string", "format": "uuid" }
                }
              }
            ]
          }
        ]
      },
      "GenerationAcceptedView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["userMessageId", "generationId", "statusUrl", "eventsUrl"],
        "properties": {
          "userMessageId": { "type": "string", "format": "uuid" },
          "generationId": { "type": "string", "format": "uuid" },
          "statusUrl": { "type": "string", "format": "uri-reference" },
          "eventsUrl": { "type": "string", "format": "uri-reference" }
        }
      },
      "GenerationView": {
        "type": "object",
        "additionalProperties": true,
        "required": ["generationId", "conversationId", "status", "content", "createdAt", "updatedAt"],
        "properties": {
          "generationId": { "type": "string", "format": "uuid" },
          "conversationId": { "type": "string", "format": "uuid" },
          "status": { "$ref": "#/components/schemas/GenerationStatus" },
          "content": { "$ref": "#/components/schemas/MessageContent" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "error": { "oneOf": [{ "$ref": "#/components/schemas/ErrorResponse" }, { "type": "null" }] }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": ["code", "message", "correlationId"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^AW-CONVERSATION-(NOT_FOUND|CONFLICT|VALIDATION|DEPENDENCY|RATE_LIMIT|INTERNAL)-[0-9]{4}$"
          },
          "message": { "type": "string", "minLength": 1 },
          "correlationId": { "type": "string", "format": "uuid" }
        }
      }
    }
  }
}
