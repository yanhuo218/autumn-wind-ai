{
  "openapi": "3.1.0",
  "info": {
    "title": "Autumn Wind Ai Model Registry Internal API",
    "version": "1.0.0",
    "description": "Inference Gateway 获取租户模型固定推理目标和加密凭据信封的内部接口。"
  },
  "security": [{ "ServiceJwt": [] }],
  "paths": {
    "/internal/v1/model-registry/inference-target-resolutions": {
      "post": {
        "operationId": "resolveInferenceTarget",
        "description": "仅返回内部传输的加密信封，绝不返回 API Key 明文。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InferenceTargetResolutionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "固定推理调用快照。",
            "headers": {
              "Cache-Control": { "$ref": "#/components/headers/NoStoreCacheControl" },
              "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InferenceTargetView" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/internal/v1/model-registry/connection-test-jobs/claims": {
      "post": {
        "operationId": "claimEndpointConnectionTestJob",
        "description": "领取最旧的等待任务或租约已过期的运行任务；没有可领取任务时返回 204。",
        "responses": {
          "200": {
            "description": "连接测试任务固定租约快照。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestJobLeaseView" }
              }
            }
          },
          "204": { "description": "当前没有可领取任务。" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/internal/v1/model-registry/connection-test-jobs/lease-renewals": {
      "post": {
        "operationId": "renewEndpointConnectionTestJobLease",
        "description": "使用当前租约和任务版本续租。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConnectionTestLeaseCommand" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "续租后的任务版本。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestJobVersionView" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/LeaseConflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/internal/v1/model-registry/connection-test-jobs/successes": {
      "post": {
        "operationId": "completeEndpointConnectionTestJobSuccessfully",
        "description": "使用当前租约和任务版本将任务完成为成功。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConnectionTestLeaseCommand" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功完成后的任务版本。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestJobVersionView" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/LeaseConflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/internal/v1/model-registry/connection-test-jobs/failures": {
      "post": {
        "operationId": "completeEndpointConnectionTestJobWithFailure",
        "description": "使用当前租约和任务版本将任务完成为稳定失败码。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConnectionTestFailureCommand" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "失败完成后的任务版本。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectionTestJobVersionView" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/LeaseConflict" },
          "406": { "$ref": "#/components/responses/NotAcceptable" },
          "415": { "$ref": "#/components/responses/UnsupportedMediaType" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ServiceJwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Service JWT 必须提供对应操作所需的 model-registry.inference.resolve 或 model-registry.connection-test.execute scope；推理目标解析还必须包含规范 actor_user_id，后台连接测试操作不要求用户 actor。"
      }
    },
    "schemas": {
      "ConnectionTestJobLeaseView": {
        "type": "object",
        "additionalProperties": false,
        "required": ["jobId", "ownerUserId", "endpointId", "endpointVersion", "credentialId", "correlationId", "leaseId", "leaseExpiresAt", "attemptCount", "jobVersion"],
        "properties": {
          "jobId": { "type": "string", "format": "uuid" },
          "ownerUserId": { "type": "string", "format": "uuid" },
          "endpointId": { "type": "string", "format": "uuid" },
          "endpointVersion": { "type": "integer", "format": "int64", "minimum": 0 },
          "credentialId": { "type": "string", "format": "uuid" },
          "correlationId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{16,64}$" },
          "leaseId": { "type": "string", "format": "uuid" },
          "leaseExpiresAt": { "type": "string", "format": "date-time" },
          "attemptCount": { "type": "integer", "minimum": 1 },
          "jobVersion": { "type": "integer", "format": "int64", "minimum": 0 }
        }
      },
      "ConnectionTestLeaseCommand": {
        "type": "object",
        "additionalProperties": false,
        "required": ["jobId", "leaseId", "jobVersion"],
        "properties": {
          "jobId": { "type": "string", "format": "uuid" },
          "leaseId": { "type": "string", "format": "uuid" },
          "jobVersion": { "type": "integer", "format": "int64", "minimum": 0 }
        }
      },
      "ConnectionTestFailureCommand": {
        "type": "object",
        "additionalProperties": false,
        "required": ["jobId", "leaseId", "jobVersion", "failureCode"],
        "properties": {
          "jobId": { "type": "string", "format": "uuid" },
          "leaseId": { "type": "string", "format": "uuid" },
          "jobVersion": { "type": "integer", "format": "int64", "minimum": 0 },
          "failureCode": {
            "type": "string",
            "enum": ["CONFIGURATION_CHANGED", "TARGET_REJECTED", "PROVIDER_AUTHENTICATION_FAILED", "PROVIDER_RATE_LIMITED", "PROVIDER_UNAVAILABLE", "PROVIDER_RESPONSE_INVALID", "PROVIDER_ERROR", "CONNECTION_FAILED", "INTERNAL_DEPENDENCY_ERROR"]
          }
        }
      },
      "ConnectionTestJobVersionView": {
        "type": "object",
        "additionalProperties": false,
        "required": ["jobId", "jobVersion"],
        "properties": {
          "jobId": { "type": "string", "format": "uuid" },
          "jobVersion": { "type": "integer", "format": "int64", "minimum": 0 }
        }
      },
      "InferenceTargetResolutionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ownerUserId", "modelId"],
        "properties": {
          "ownerUserId": { "type": "string", "format": "uuid" },
          "modelId": { "type": "string", "format": "uuid" }
        }
      },
      "InferenceTargetView": {
        "type": "object",
        "additionalProperties": false,
        "required": ["modelId", "providerModelId", "modelVersion", "endpointId", "endpointBaseUrl", "endpointProtocol", "endpointRequestTimeoutSeconds", "endpointVersion", "capabilities", "credentialId", "credential"],
        "properties": {
          "modelId": { "type": "string", "format": "uuid" },
          "providerModelId": { "type": "string" },
          "modelVersion": { "type": "integer", "format": "int64", "minimum": 0 },
          "endpointId": { "type": "string", "format": "uuid" },
          "endpointBaseUrl": { "type": "string", "format": "uri" },
          "endpointProtocol": { "type": "string", "enum": ["OPENAI_COMPATIBLE"] },
          "endpointRequestTimeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 120 },
          "endpointVersion": { "type": "integer", "format": "int64", "minimum": 0 },
          "capabilities": { "$ref": "#/components/schemas/ModelCapabilities" },
          "credentialId": { "type": "string", "format": "uuid" },
          "credential": { "$ref": "#/components/schemas/EncryptedCredentialEnvelope" }
        }
      },
      "ModelCapabilities": {
        "type": "object",
        "additionalProperties": false,
        "required": ["interfaceType", "inputModalities", "outputModality", "streaming", "systemPrompt", "reasoning", "contextLength", "maxOutputLength"],
        "properties": {
          "interfaceType": { "type": "string", "enum": ["CHAT_COMPLETIONS", "IMAGE_GENERATION"] },
          "inputModalities": { "type": "array", "items": { "type": "string", "enum": ["TEXT", "IMAGE", "FILE", "VIDEO"] } },
          "outputModality": { "type": "string", "enum": ["TEXT", "IMAGE"] },
          "streaming": { "type": "boolean" },
          "systemPrompt": { "type": "boolean" },
          "reasoning": { "type": "boolean" },
          "contextLength": { "type": "integer", "minimum": 1 },
          "maxOutputLength": { "type": "integer", "minimum": 1 }
        }
      },
      "EncryptedCredentialEnvelope": {
        "type": "object",
        "description": "仅内部传输的加密信封，不包含 API Key 明文。",
        "additionalProperties": false,
        "required": ["version", "keyId", "wrappedDataKeyNonce", "wrappedDataKey", "payloadNonce", "ciphertext"],
        "properties": {
          "version": { "type": "integer", "minimum": 1 },
          "keyId": { "type": "string" },
          "wrappedDataKeyNonce": { "type": "string", "contentEncoding": "base64" },
          "wrappedDataKey": { "type": "string", "contentEncoding": "base64" },
          "payloadNonce": { "type": "string", "contentEncoding": "base64" },
          "ciphertext": { "type": "string", "contentEncoding": "base64" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": ["code", "message", "correlationId"],
        "properties": {
          "code": { "type": "string", "pattern": "^AW-MODEL_REGISTRY-[A-Z][A-Z0-9_]{1,31}-[0-9]{4}$" },
          "message": { "type": "string" },
          "correlationId": { "type": "string", "minLength": 16, "maxLength": 64 },
          "fieldErrors": { "type": "array", "items": { "type": "object" } }
        }
      }
    },
    "responses": {
      "BadRequest": { "$ref": "#/components/responses/Error400" },
      "Unauthorized": { "$ref": "#/components/responses/Error401" },
      "Forbidden": { "$ref": "#/components/responses/Error403" },
      "NotFound": { "$ref": "#/components/responses/Error404" },
      "Conflict": { "$ref": "#/components/responses/Error409" },
      "LeaseConflict": { "description": "任务租约、版本或运行状态不匹配。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "NotAcceptable": { "$ref": "#/components/responses/Error406" },
      "UnsupportedMediaType": { "$ref": "#/components/responses/Error415" },
      "InternalServerError": { "$ref": "#/components/responses/Error500" },
      "Error400": { "description": "请求不合法。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error401": { "description": "Service JWT 无效或缺失。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error403": { "description": "无权访问。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error404": { "description": "模型不存在。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error409": { "description": "推理目标不可用。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error406": { "description": "响应媒体类型不受支持。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error415": { "description": "请求媒体类型不受支持。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "Error500": { "description": "服务器内部错误。", "headers": { "X-Correlation-ID": { "$ref": "#/components/headers/CorrelationId" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
    },
    "headers": {
      "CorrelationId": { "description": "请求关联标识。", "schema": { "type": "string", "minLength": 16, "maxLength": 64 } },
      "NoStoreCacheControl": { "description": "加密凭据响应不得被缓存。", "schema": { "type": "string", "const": "no-store" } }
    }
  }
}
