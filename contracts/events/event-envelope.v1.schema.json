{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:autumn-wind-ai:events:event-envelope:v1",
  "title": "Autumn Wind Ai 事件 Envelope V1",
  "description": "所有领域事件和后台任务事件共享的外层结构。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "producer",
    "correlationId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]{2,63}$"
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "correlationId": {
      "type": "string",
      "minLength": 16,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
